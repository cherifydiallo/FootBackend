            ],
            "url": {
              "raw": "{{baseUrl}}/players/{{playerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["players", "{{playerId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ali Ben Salah\",\n  \"birthDate\": \"2005-03-15\",\n  \"academy\": \"Academy Tunis\",\n  \"category\": \"U21\",\n  \"registerNumber\": \"REG-2024-001\",\n  \"heightCm\": 179,\n  \"weightKg\": 74,\n  \"fatherName\": \"Mohamed Ben Salah\",\n  \"motherName\": \"Fatma Trabelsi\",\n  \"photo\": \"ali_ben_salah.jpg\"\n}"
            }
