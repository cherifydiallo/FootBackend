{
  "info": {
    "name": "FootBackend API",
    "_postman_id": "footbackend-collection-v2",
    "description": "REST endpoints for FootBackend. Login first to populate {{token}}. Note: /auth/signup is protected and requires user_write permission.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "1" },
    { "key": "groupId", "value": "1" },
    { "key": "playerId", "value": "1" },
    { "key": "permissionKey", "value": "user_read" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifiant\": \"admin\",\n  \"password\": \"Start123\"\n}"
            }
          }
        },
        {
          "name": "Signup (requires user_write)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifiant\": \"johndoe\",\n  \"password\": \"secret123\",\n  \"fullname\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"role\": \"standard\"\n}"
            }
          }
        },
        {
          "name": "Check Token",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/check",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "check"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{token}}\"\n}"
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/users",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "users"]
            }
          }
        },
        {
          "name": "Search User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/user/search?username=john",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "user", "search"],
              "query": [
                { "key": "username", "value": "john" }
              ]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "users", "{{userId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"John Updated\",\n  \"email\": \"john.updated@example.com\",\n  \"password\": \"\",\n  \"role\": \"standard\"\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "users", "{{userId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/profile/me",
              "host": ["{{baseUrl}}"],
              "path": ["profile", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Groups",
      "item": [
        {
          "name": "Create Group",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups",
              "host": ["{{baseUrl}}"],
              "path": ["groups"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Team A\",\n  \"description\": \"First team\"\n}"
            }
          }
        },
        {
          "name": "Get All Groups",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups/all",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "all"]
            }
          }
        },
        {
          "name": "Get Group By Id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}"]
            }
          }
        },
        {
          "name": "Update Group",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Team A Updated\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete Group",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}"]
            }
          }
        },
        {
          "name": "Add User To Group",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups/add-user",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "add-user"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"groupId\": {{groupId}}\n}"
            }
          }
        },
        {
          "name": "Remove User From Group",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups/remove-user",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "remove-user"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"groupId\": {{groupId}}\n}"
            }
          }
        },
        {
          "name": "Get Group Members",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}/members",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}", "members"]
            }
          }
        },
        {
          "name": "Get Group Permissions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}/permissions",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}", "permissions"]
            }
          }
        },
        {
          "name": "Upsert Group Permission",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}/permissions",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}", "permissions"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permissionKey\": \"{{permissionKey}}\",\n  \"enabled\": true,\n  \"description\": \"Granted by Postman\"\n}"
            }
          }
        },
        {
          "name": "Delete Group Permission",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}/permissions/{{permissionKey}}",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}", "permissions", "{{permissionKey}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Players",
      "item": [
        {
          "name": "Create Player",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/players",
              "host": ["{{baseUrl}}"],
              "path": ["players"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ali Ben Salah\",\n  \"birthDate\": \"2005-03-15\",\n  \"academy\": \"Academy Tunis\",\n  \"category\": \"U20\",\n  \"registerNumber\": \"REG-2024-001\",\n  \"heightCm\": 178,\n  \"weightKg\": 72,\n  \"fatherName\": \"Mohamed Ben Salah\",\n  \"motherName\": \"Fatma Trabelsi\",\n  \"photo\": \"ali_ben_salah.jpg\"\n}"
            }
          }
        },
        {
