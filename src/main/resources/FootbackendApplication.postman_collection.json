            ],
            "url": {
              "raw": "{{baseUrl}}/players/all",
              "host": ["{{baseUrl}}"],
              "path": ["players", "all"]
            }
          }
        },
        {
          "name": "Get Player By Id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/players/{{playerId}}",
              "host": ["{{baseUrl}}"],
              "path": ["players", "{{playerId}}"]
            }
          }
        },
        {
          "name": "Search Player By Register Number",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/players/search?registerNumber=REG-2024-001",
              "host": ["{{baseUrl}}"],
              "path": ["players", "search"],
              "query": [
                { "key": "registerNumber", "value": "REG-2024-001" }
              ]
            }
          }
        },
        {
          "name": "Update Player",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
